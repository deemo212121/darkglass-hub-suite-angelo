# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration (Authentication + Storage)
# Get these from Firebase Console: https://console.firebase.google.com/
# Project Settings > General > Your apps > Web app config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id_here

# Supabase Configuration (Business Data - NOT READY YET)
# Get these from Supabase Dashboard: https://app.supabase.com/
# Project Settings > API > Project URL and anon/public key
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Jotform webhook (SERVER ONLY - no VITE_ prefix, never exposed to browser)
JOTFORM_WEBHOOK_SECRET=your_jotform_webhook_secret_here
JOTFORM_TARGET_COMPANY_ID=your_target_company_uuid_here
# Used to download file-upload answers (Jotform's URLs redirect to login without it)
JOTFORM_API_KEY=your_jotform_api_key_here

# Firebase service account (SERVER ONLY) used to write notifications via the
# Firestore REST API from the Jotform webhook, since the Firebase client SDK
# does not run reliably on Cloudflare Workers. Create one at:
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# Copy "client_email" as-is, and "private_key" with its \n sequences kept literal.
FIREBASE_SERVICE_ACCOUNT_EMAIL=your_service_account_email_here
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
